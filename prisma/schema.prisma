generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomStatus {
  LOBBY
  LIVE
  ENDED
}

enum PlatformType {
  YOUTUBE
  TWITCH
  KICK
  TIKTOK
}

enum StreamStatus {
  STARTING
  LIVE
  STOPPING
  ENDED
  FAILED
}

enum ParticipantRole {
  HOST
  GUEST
}

model User {
  id                  String                  @id @default(cuid())
  name                String?
  email               String                  @unique
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  sessions            Session[]
  platformConnections PlatformConnection[]
  customRtmp          CustomRtmpDestination[]
  rooms               Room[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlatformConnection {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        PlatformType
  channelId       String
  channelName     String
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  streamKey       String? // RTMP stream key (encrypted at rest by Neon)
  ingestUrl       String? // Custom RTMP ingest URL (mainly for TikTok)
  backupIngestUrl String? // YouTube backup ingest URL (rtmp://b.rtmp.youtube.com/live2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, platform])
}

model Room {
  id                String          @id @default(cuid())
  code              String          @unique
  title             String?
  description       String? // Broadcast description (sent to platforms)
  thumbnailUrl      String? // Optional thumbnail URL for YouTube broadcasts
  hostId            String
  host              User            @relation(fields: [hostId], references: [id])
  status            RoomStatus      @default(LOBBY)
  autoAdmit         Boolean         @default(false)
  selectedPlatforms PlatformType[]
  createdAt         DateTime        @default(now())
  endedAt           DateTime?
  participants      Participant[]
  streamSessions    StreamSession[]
  guestLeads        GuestLead[]
}

model Participant {
  id       String          @id @default(cuid())
  roomId   String
  room     Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name     String
  identity String // LiveKit identity string (e.g., "host-xxx" or "guest-xxx")
  role     ParticipantRole
  joinedAt DateTime        @default(now())
  leftAt   DateTime?

  @@index([roomId])
}

model GuestLead {
  id       String   @id @default(cuid())
  roomId   String
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name     String
  email    String
  joinedAt DateTime @default(now())

  @@index([roomId])
  @@index([email])
}

model CustomRtmpDestination {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // Display name (e.g. "Facebook", "LinkedIn", "My Server")
  ingestUrl String // RTMP server URL
  streamKey String // Stream key
  createdAt DateTime @default(now())

  @@index([userId])
}

model StreamSession {
  id            String         @id @default(cuid())
  roomId        String
  room          Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  egressId      String?        @unique // LiveKit egress ID
  platforms     PlatformType[] // Which platforms are being streamed to
  status        StreamStatus   @default(STARTING)
  startedAt     DateTime       @default(now())
  endedAt       DateTime?
  error         String? // Error message if FAILED
  recordingPath        String? // R2 object key (e.g. "recordings/ABC-12345.mp4")
  recordingUrl         String? // Presigned download URL, expires per S3 TTL
  recordingUrlMintedAt DateTime? // When recordingUrl was last (re)issued — drives staleness check

  @@index([roomId])
}

model BetaRequest {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  platform  String
  painPoint String?
  createdAt DateTime @default(now())
}
